# ── SolKBD Portfolio — environment template ──
# Copy to .env and fill in real values. NEVER commit .env to git.

# Contact form destination
CONTACT_EMAIL_TO=

# SMTP (TLS on 587 recommended)
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASSWORD=

# GitHub API (Phase 5 — /api/github-repos proxy)
GITHUB_TOKEN=
GITHUB_USERNAME=solmuz
GITHUB_EXCLUDE_REPOS=SIGRH

# CORS — comma-separated origins allowed to hit the API
ALLOWED_ORIGINS=

# Cloudflare Tunnel (homelab — create tunnel at dash.cloudflare.com > Zero Trust > Networks > Tunnels)
TOKEN=
